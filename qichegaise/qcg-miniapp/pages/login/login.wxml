<!-- pages/login/login.wxml -->
<view class="container">
  <view class="hero">
    <view class="logo">🚗</view>
    <text class="title">汽车改色膜预览</text>
    <text class="subtitle">上传你的爱车，即刻预览换色效果</text>
  </view>

  <view class="login-box">
    <button class="login-btn" bindtap="onLogin" loading="{{loading}}" disabled="{{loading}}">
      <text wx:if="{{!loading}}">微信一键登录</text>
      <text wx:else>登录中...</text>
    </button>

    <view class="login-error" wx:if="{{loginError}}">
      <text>{{loginError}}</text>
    </view>

    <view class="login-tip">
      <text>点击上方按钮授权登录</text>
      <text>登录后即可使用全部功能</text>
    </view>
  </view>
</view>

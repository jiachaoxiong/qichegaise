.brand-filter {
  white-space: nowrap;
  padding: 16rpx 0;
  background: #fff;
  margin-bottom: 16rpx;
  width: 100%;
}
.brand-filter .brand-item {
  display: inline-block;
  padding: 12rpx 28rpx;
  font-size: 26rpx;
  color: #666;
  flex-shrink: 0;
}
.brand-item.active {
  color: #ff4444;
  font-weight: 600;
}
.model-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 0 16rpx;
}
.model-card {
  width: calc(50% - 16rpx);
  margin: 8rpx;
  background: #fff;
  border-radius: 12rpx;
  overflow: hidden;
}
.model-img {
  width: 100%;
  height: 240rpx;
  background: #eee;
}
.model-img.placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #667eea, #764ba2);
}
.placeholder-icon {
  font-size: 72rpx;
}
.model-name {
  display: block;
  font-size: 26rpx;
  color: #333;
  padding: 12rpx 16rpx 4rpx;
  font-weight: 500;
}
.model-type {
  display: block;
  font-size: 22rpx;
  color: #999;
  padding: 0 16rpx 12rpx;
}
